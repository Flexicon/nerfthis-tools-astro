<div class="px-6 py-6 bg-white rounded-lg border border-gray-200 shadow-sm">
  <div class="mb-6">
    <label for="unicode-input" class="block text-sm font-medium text-gray-700 mb-2"> Enter Unicode text: </label>
    <textarea
      id="unicode-input"
      class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono text-sm"
      rows="4"
      placeholder="Type or paste any text here... 👋 Hello 世界 🌍"></textarea>
  </div>

  <div class="mb-6">
    <label class="block text-sm font-medium text-gray-700 mb-2" for="format"> Conversion format: </label>
    <div class="flex gap-4 flex-wrap">
      <label class="inline-flex items-center">
        <input
          type="radio"
          name="format"
          value="decimal"
          checked
          class="form-radio text-blue-600 focus:ring-blue-500"
        />
        <span class="ml-2 text-sm">Decimal (&amp;#8230;)</span>
      </label>
      <label class="inline-flex items-center">
        <input type="radio" name="format" value="hex" class="form-radio text-blue-600 focus:ring-blue-500" />
        <span class="ml-2 text-sm">Hexadecimal (&amp;#x2026;)</span>
      </label>
      <label class="inline-flex items-center">
        <input type="radio" name="format" value="named" class="form-radio text-blue-600 focus:ring-blue-500" />
        <span class="ml-2 text-sm">Named when possible (&amp;copy;)</span>
      </label>
    </div>
  </div>

  <div class="mb-4">
    <div class="flex items-center justify-between mb-2">
      <label for="html-output" class="block text-sm font-medium text-gray-700"> HTML entities output: </label>
      <button
        id="copy-btn"
        class="px-3 py-1 text-xs font-medium text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded transition-colors duration-150"
      >
        Copy to clipboard
      </button>
    </div>
    <textarea
      id="html-output"
      readonly
      class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50 font-mono text-sm"
      rows="4"
      placeholder="HTML entities will appear here..."></textarea>
  </div>

  <div id="copy-success" class="opacity-0 text-sm text-green-600 text-center py-2">✓ Copied to clipboard!</div>
</div>

<script>
  function unicodeToHtml(text: string): string {
    return Array.from(text)
      .map((char) => {
        const codePoint = char.codePointAt(0);
        if (!codePoint) return char;

        if (codePoint > 127) {
          return `&#${codePoint};`;
        }
        return char;
      })
      .join('');
  }

  function unicodeToHtmlHex(text: string): string {
    return Array.from(text)
      .map((char) => {
        const codePoint = char.codePointAt(0);
        if (!codePoint) return char;

        if (codePoint > 127) {
          return `&#x${codePoint.toString(16).toUpperCase()};`;
        }
        return char;
      })
      .join('');
  }

  function unicodeToHtmlNamed(text: string): string {
    const namedEntities: Record<number, string> = {
      34: '&quot;',
      38: '&amp;',
      39: '&apos;',
      60: '&lt;',
      62: '&gt;',
      160: '&nbsp;',
      161: '&iexcl;',
      162: '&cent;',
      163: '&pound;',
      164: '&curren;',
      165: '&yen;',
      166: '&brvbar;',
      167: '&sect;',
      168: '&uml;',
      169: '&copy;',
      170: '&ordf;',
      171: '&laquo;',
      172: '&not;',
      173: '&shy;',
      174: '&reg;',
      175: '&macr;',
      176: '&deg;',
      177: '&plusmn;',
      178: '&sup2;',
      179: '&sup3;',
      180: '&acute;',
      181: '&micro;',
      182: '&para;',
      183: '&middot;',
      184: '&cedil;',
      185: '&sup1;',
      186: '&ordm;',
      187: '&raquo;',
      188: '&frac14;',
      189: '&frac12;',
      190: '&frac34;',
      191: '&iquest;',
      215: '&times;',
      247: '&divide;',
    };

    return Array.from(text)
      .map((char) => {
        const codePoint = char.codePointAt(0);
        if (!codePoint) return char;

        if (namedEntities[codePoint]) {
          return namedEntities[codePoint];
        }

        if (codePoint > 127) {
          return `&#${codePoint};`;
        }
        return char;
      })
      .join('');
  }

  // Hook into DOM elements
  const inputEl = document.getElementById('unicode-input') as HTMLTextAreaElement;
  const outputEl = document.getElementById('html-output') as HTMLTextAreaElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copySuccess = document.getElementById('copy-success') as HTMLDivElement;
  const formatRadios = document.querySelectorAll('input[name="format"]');

  // Main logic entrypoint
  function convert() {
    const text = inputEl.value;
    const selectedFormat =
      (document.querySelector('input[name="format"]:checked') as HTMLInputElement)?.value || 'decimal';

    let result = '';
    switch (selectedFormat) {
      case 'hex':
        result = unicodeToHtmlHex(text);
        break;
      case 'named':
        result = unicodeToHtmlNamed(text);
        break;
      case 'decimal':
      default:
        result = unicodeToHtml(text);
    }

    outputEl.value = result;
  }

  // Event listeners
  inputEl.addEventListener('input', convert);
  formatRadios.forEach((radio) => {
    radio.addEventListener('change', convert);
  });
  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(outputEl.value);
      copySuccess.classList.remove('opacity-0');
      setTimeout(() => {
        copySuccess.classList.add('opacity-0');
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>
