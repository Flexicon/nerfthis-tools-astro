---
import ToolsIcon from "../components/ToolsIcon.astro";
import "../styles/global.css";

export interface Props {
  title: string;
}

const pathname = new URL(Astro.request.url).pathname;

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="generator" content={Astro.generator} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="leading-8">
    <header class="py-3 px-5 bg-zinc-800 text-white">
      <nav class="max-w-277.5 mx-auto">
        <div class="flex items-center justify-between">
          <a href="/" class="flex items-center gap-2 text-2xl">
            <ToolsIcon />
            <strong>NerfThis Tools</strong>
          </a>

          <!-- Hamburger toggle (hidden checkbox) -->
          <input type="checkbox" id="nav-toggle" class="hidden" />

          <!-- Overlay for click-outside-to-close (only visible when menu open) -->
          <label for="nav-toggle" class="nav-overlay"></label>

          <!-- Hamburger icon (only visible on mobile) -->
          <label for="nav-toggle" class="hamburger md:hidden cursor-pointer">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
          </label>

          <!-- Navigation menu -->
          <div role="navigation" class="nav-menu">
            <ul class="nav-list">
              <li>
                <a
                  class={["nav-link", pathname === "/ip" && "active"].join(" ")}
                  href="/ip">IP Address</a
                >
              </li>
              <li>
                <a
                  class={["nav-link", pathname === "/unicode" && "active"].join(" ")}
                  href="/unicode">Unicode to HTML</a
                >
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
